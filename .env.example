# ────────────────────────────────────────────────────────────
# Supabase — get these from your Supabase project's API settings
# (Project Settings → API)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only key — used by server actions to bypass RLS for admin operations
# (Project Settings → API → service_role secret)
# NEVER expose this on the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────────────────
# JWT signing secret for admin sessions (custom auth)
# Generate with:  openssl rand -base64 48
# ────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=replace-me-with-a-long-random-string

# ────────────────────────────────────────────────────────────
# Public origin used for QR codes (room links)
# In production set this to your deployed domain.
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
